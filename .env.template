# ShadowBrain — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ──────────────────────────────────────────────
DOMAIN=localhost:3000
PORT=3000
NODE_ENV=development

# ── Database ────────────────────────────────────────────
# Directory where SQLite databases are stored (relative to project root).
# Content (images) is also served from this directory — see
# src/lib/storage.ts and the `/api/images/[...path]` route.
DATA_DIR=./data



# ── Discord Integration ────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Server (guild) ID where the bot operates
DISCORD_GUILD_ID=
# Channel ID for journal/digest output
DISCORD_JOURNAL_CHANNEL_ID=

# ── AI Provider (OpenRouter) ────────────────────────────
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model identifier in provider/model format
# See available models: https://openrouter.ai/models
AI_MODEL=mistralai/mistral-7b-instruct

# ── Embeddings (semantic search) ───────────────────────
# Local sentence-transformers model name
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Authentication ─────────────────────────────────────
# Required. Random secret for session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=
# Optional. Session lifetime in ms, clamped to [1h, 30d]. Default: 24h (86400000).
SESSION_MAX_AGE=86400000
# Required. Single-user admin username.
ADMIN_USERNAME=
# Required. Bcrypt hash of the admin password (cost >= 10).
# Generate with: pnpm dlx bcrypt-cli hash 'YOUR_PASSWORD'
ADMIN_PASSWORD_HASH=

# ── Email (optional — for email-to-inbox) ──────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=inbox@your-domain.com
# SMTP_PASS=your-password

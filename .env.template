# ShadowBrain — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ──────────────────────────────────────────────
DOMAIN=localhost:3000
PORT=3000
NODE_ENV=development

# ── Database ────────────────────────────────────────────
# Directory where SQLite databases are stored (relative to project root)
DATA_DIR=./data

# ── Discord Integration ────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Server (guild) ID where the bot operates
DISCORD_GUILD_ID=
# Channel ID for journal/digest output
DISCORD_JOURNAL_CHANNEL_ID=

# ── AI Provider (OpenRouter) ────────────────────────────
# API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model identifier in provider/model format
# See available models: https://openrouter.ai/models
AI_MODEL=mistralai/mistral-7b-instruct

# ── Embeddings (semantic search) ───────────────────────
# Local sentence-transformers model name
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Authentication ─────────────────────────────────────
# Random secret for session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=

# ── Email (optional — for email-to-inbox) ──────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=inbox@your-domain.com
# SMTP_PASS=your-password

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "3 days",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-non-major",
      "schedule": ["before 5am on monday"]
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Defer eslint v10 major until eslint-plugin-react (transitive via eslint-config-next) ships ESLint 10 support. Tracking: jsx-eslint/eslint-plugin-react#3977.",
      "matchPackageNames": ["eslint", "eslint-config-next"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}

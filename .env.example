# ShadowBrain — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# ── Server ──────────────────────────────────────────────
DOMAIN=your-domain.com
PORT=3000

# ── Database ────────────────────────────────────────────
DATA_DIR=./data

# ── Discord ─────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_JOURNAL_CHANNEL_ID=your-channel-id

# ── AI (OpenRouter) ─────────────────────────────────────
OPENROUTER_API_KEY=your-api-key
AI_MODEL=mistralai/mistral-7b-instruct

# ── Embeddings (for semantic search) ────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Auth ────────────────────────────────────────────────
SESSION_SECRET=generate-a-random-secret-here

# ── Email (optional, for email-to-inbox) ────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=inbox@your-domain.com
# SMTP_PASS=your-password
